<mujocoinclude>
    <!-- High performance physics engine settings -->
    <option timestep='0.002' iterations="200" tolerance="1e-8" solver="Newton" jacobian="dense" cone="elliptic" />"

    <asset>
        <mesh file="tabletop.stl" name="tabletop" scale="0.001 0.001 0.001"/>
        <!-- High-quality material definitions with enhanced reflections -->
        <material name="table_material" rgba="0.15 0.15 0.15 1" shininess="0.4" specular="0.3"/>
        <material name="red_peg_material" rgba="0.95 0.15 0.15 1" shininess="1.0" specular="0.8"/>
        <material name="red_box_material" rgba="0.95 0.15 0.15 1" shininess="1.0" specular="0.8"/>
        <material name="blue_socket_material" rgba="0.15 0.15 0.95 1" shininess="1.0" specular="0.7"/>
        <material name="platform_material" rgba="0.3 0.8 0.3 0" shininess="0.2" specular="0.1"/>
    </asset>

    <visual>
        <map fogstart="1.5" fogend="5" force="0.1" znear="0.1"/>
        <quality shadowsize="4096" offsamples="16" />
        <headlight ambient="0.5 0.5 0.5" diffuse="0.6 0.6 0.6" specular="0.3 0.3 0.3"/>
    </visual>

    <worldbody>
        <!-- Strong main light with shadows for crisp details -->
        <light castshadow="true" directional='true' diffuse='0.7 0.7 0.7' specular='0.4 0.4 0.4' pos='0 0.6 3'
               dir='0 0 -1'/>
        <!-- Strong fill light for enhanced visibility -->
        <light castshadow="false" directional='true' diffuse='0.6 0.6 0.6' specular='0.2 0.2 0.2' pos='0 0.6 1'
               dir='0 0 -1'/>

        <body name="table" pos="0 .6 0">
            <geom group="1" mesh="tabletop" pos="0 0 0" type="mesh" conaffinity="1" contype="1" name="table" material="table_material" friction="0.01 0.001 0.0001" />
        </body>
        <body name="midair" pos="0 .6 0.2">
            <site pos="0 0 0" size="0.01" type="sphere" name="midair" rgba="1 0 0 0"/>
        </body>

        <camera name="left_pillar" pos="-0.1 0.1 0.7" fovy="78" euler="0.7 0 0"/>
        <camera name="right_pillar" pos="0.1 0.1 0.7" fovy="78" euler="0.7 0 0"/>
        <camera name="angle" pos="0 0.1 0.7" fovy="78" euler="0.7 0 0"/>
        <camera name="angle_down" pos="0 0.1 0.5" fovy="78" euler="0.7 0 0"/>
        <camera name="top" pos="0 0.6 0.8" fovy="78" mode="targetbody" target="table"/>
        <camera name="front_close" pos="0 0.2 0.4" fovy="78" mode="targetbody" target="vx300s_left/camera_focus"/>

    </worldbody>



</mujocoinclude>
