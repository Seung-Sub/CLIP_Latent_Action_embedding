<mujoco>
    <include file="scene.xml"/>
    <include file="vx300s_dependencies.xml"/>

    <asset>
        <material name="blue_box_material"  rgba="0.15 0.15 0.95 1" shininess="1.0" specular="0.8"/>
        <!-- Plate colors are deliberately offset from the cube colors so they
             are distinguishable: red plate -> coral, blue plate -> teal. -->
        <material name="red_goal_material"  rgba="0.95 0.55 0.30 0.7"/>
        <material name="blue_goal_material" rgba="0.30 0.70 0.70 0.7"/>
    </asset>

    <contact>
        <exclude body1="red_goal"  body2="table"/>
        <exclude body1="blue_goal" body2="table"/>
    </contact>

    <worldbody>
        <include file="vx300s_left.xml" />
        <include file="vx300s_right.xml" />

        <body name="red_goal" pos="-0.10 0.30 0.0375">
            <geom type="box" size="0.04 0.04 0.0075"
                  name="red_goal_geom" friction="0.5 0.1 0.001"
                  material="red_goal_material" />
        </body>
        <body name="blue_goal" pos="0.10 0.30 0.0375">
            <geom type="box" size="0.04 0.04 0.0075"
                  name="blue_goal_geom" friction="0.5 0.1 0.001"
                  material="blue_goal_material" />
        </body>

        <body name="red_box" pos="-0.10 0.65 0.05">
            <joint name="red_box_joint" type="free" frictionloss="0.01" />
            <inertial pos="0 0 0" mass="0.05" diaginertia="0.002 0.002 0.002" />
            <geom condim="4" solimp="0.99 0.99 0.001" solref="0.002 1" friction="4.0 0.1 0.002" pos="0 0 0" size="0.02 0.02 0.02" type="box" name="red_box" material="red_box_material" />
        </body>

        <body name="blue_box" pos="0.10 0.65 0.05">
            <joint name="blue_box_joint" type="free" frictionloss="0.01" />
            <inertial pos="0 0 0" mass="0.05" diaginertia="0.002 0.002 0.002" />
            <geom condim="4" solimp="0.99 0.99 0.001" solref="0.002 1" friction="4.0 0.1 0.002" pos="0 0 0" size="0.02 0.02 0.02" type="box" name="blue_box" material="blue_box_material" />
        </body>

    </worldbody>

    <actuator>
        <position ctrllimited="true" ctrlrange="-3.14158 3.14158" joint="vx300s_left/waist" kp="800"  user="1" forcelimited="true" forcerange="-150 150"/>
        <position ctrllimited="true" ctrlrange="-1.85005 1.25664" joint="vx300s_left/shoulder" kp="1600"  user="1" forcelimited="true" forcerange="-300 300"/>
        <position ctrllimited="true" ctrlrange="-1.76278 1.6057" joint="vx300s_left/elbow" kp="800"  user="1" forcelimited="true" forcerange="-100 100"/>
        <position ctrllimited="true" ctrlrange="-3.14158 3.14158" joint="vx300s_left/forearm_roll" kp="10"  user="1" forcelimited="true" forcerange="-100 100"/>
        <position ctrllimited="true" ctrlrange="-1.8675 2.23402" joint="vx300s_left/wrist_angle" kp="50"  user="1"/>
        <position ctrllimited="true" ctrlrange="-3.14158 3.14158" joint="vx300s_left/wrist_rotate" kp="20"  user="1"/>
        <position ctrllimited="true" ctrlrange="0.021 0.057" joint="vx300s_left/left_finger" kp="200" kv="10" user="1"/>
        <position ctrllimited="true" ctrlrange="-0.057 -0.021" joint="vx300s_left/right_finger" kp="200" kv="10" user="1"/>

        <position ctrllimited="true" ctrlrange="-3.14158 3.14158" joint="vx300s_right/waist" kp="800"  user="1" forcelimited="true" forcerange="-150 150"/>
        <position ctrllimited="true" ctrlrange="-1.85005 1.25664" joint="vx300s_right/shoulder" kp="1600"  user="1" forcelimited="true" forcerange="-300 300"/>
        <position ctrllimited="true" ctrlrange="-1.76278 1.6057" joint="vx300s_right/elbow" kp="800"  user="1" forcelimited="true" forcerange="-100 100"/>
        <position ctrllimited="true" ctrlrange="-3.14158 3.14158" joint="vx300s_right/forearm_roll" kp="10"  user="1" forcelimited="true" forcerange="-100 100"/>
        <position ctrllimited="true" ctrlrange="-1.8675 2.23402" joint="vx300s_right/wrist_angle" kp="50"  user="1"/>
        <position ctrllimited="true" ctrlrange="-3.14158 3.14158" joint="vx300s_right/wrist_rotate" kp="20"  user="1"/>
        <position ctrllimited="true" ctrlrange="0.021 0.057" joint="vx300s_right/left_finger" kp="200" kv="10" user="1"/>
        <position ctrllimited="true" ctrlrange="-0.057 -0.021" joint="vx300s_right/right_finger" kp="200" kv="10" user="1"/>

    </actuator>

    <keyframe>
        <key qpos="0 -0.96 1.16 0 -0.3 0 0.024 -0.024  0 -0.96 1.16 0 -0.3 0 0.024 -0.024  -0.10 0.65 0.05 1 0 0 0  0.10 0.65 0.05 1 0 0 0"/>
    </keyframe>

</mujoco>
